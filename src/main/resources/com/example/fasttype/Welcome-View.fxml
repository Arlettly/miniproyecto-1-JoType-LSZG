        </VBox>
    </StackPane>

    <!-- ═══════════════════════════════════════
         CONTENIDO PRINCIPAL
         ═══════════════════════════════════════ -->
    <VBox alignment="TOP_CENTER" prefHeight="500" prefWidth="320" spacing="0">
        <padding>
            <Insets bottom="10" left="20" right="20" top="22" />
        </padding>

        <!-- Título "Escritura" rojo -->
        <Label style="-fx-font-size: 54px; -fx-font-weight: bold; -fx-text-fill: #CC0000; -fx-font-family: 'Gloucester MT Extra Condensed';" text="Escritura" />

        <!-- Título "Rápida" rosa -->
        <Label style="-fx-font-size: 50px; -fx-font-weight: bold; -fx-text-fill: #FF8FAB; -fx-font-family: 'Gloucester MT Extra Condensed'; -fx-padding: -10 0 0 0;" text="Rápida" />

        <!-- Subtítulo -->
        <Label alignment="CENTER" prefWidth="260" style="-fx-font-size: 13px; -fx-text-fill: #555555;                       -fx-font-family: 'Georgia'; -fx-padding: 6 0 0 0;" text="¡Mejora tu velocidad!" textAlignment="CENTER" wrapText="true" />

        <!-- Círculo con Hello Kitty -->
        <StackPane prefHeight="200" prefWidth="280">
            <VBox.margin><Insets top="8" /></VBox.margin>

            <!-- Imagen Hello Kitty (cargada desde WelcomeController) -->
            <ImageView fx:id="characterImage" fitHeight="180" fitWidth="180" preserveRatio="true" StackPane.alignment="CENTER" />

        </StackPane>

        <!-- Botón ¡JUGAR! -->
        <StackPane>
            <VBox.margin><Insets top="14" /></VBox.margin>
            <Rectangle arcHeight="50" arcWidth="50" fill="#8B0000" height="58" mouseTransparent="true" opacity="0.7" translateY="5" width="260" />
            <Rectangle arcHeight="50" arcWidth="50" fill="#CC0000" height="58" width="260" />
            <Button fx:id="playBtn" onAction="#handlePlay" style="-fx-background-color: transparent;                            -fx-font-size: 20px; -fx-font-weight: bold;                            -fx-text-fill: white; -fx-cursor: hand;                            -fx-font-family: 'Arial Black';" text="¡JUGAR!  ▶" />
        </StackPane>

        <!-- Footer -->
        <HBox alignment="CENTER" spacing="5">
            <VBox.margin><Insets top="16" /></VBox.margin>
            <Label style="-fx-font-size: 12px; -fx-text-fill: #AAAAAA;                           -fx-font-family: 'Georgia';" text="Escribe rápido, piensa más rápido." />
            <Label style="-fx-font-size: 12px; -fx-text-fill: #CC0000;" text="❤" />
        </HBox>

    </VBox>

