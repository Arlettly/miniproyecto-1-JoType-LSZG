<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="500.0" prefWidth="320"
           style="-fx-background-color: #FFF0F0;"
           xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.fasttype.controller.GameController">

    <!-- ═══════════════════════════════════════════
         MAIN GAME PANEL
         ═══════════════════════════════════════════ -->
    <VBox alignment="TOP_CENTER" spacing="16">
        <padding>
            <Insets bottom="20" left="20" right="20" top="20" />
        </padding>

        <!-- Header: Nivel + Timer -->
        <HBox alignment="CENTER_LEFT" spacing="10">

            <!-- Nivel badge -->
            <StackPane>
                <Rectangle arcHeight="20" arcWidth="20" fill="#FFD6D6"
                           height="32" stroke="#FF6B6B" strokeWidth="1.5" width="110" />
                <Label fx:id="levelLabel"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #FF4444;"
                       text="★ Nivel: 1" />
            </StackPane>

            <!-- Timer icon + countdown + bar -->
            <HBox alignment="CENTER" spacing="6" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 16px; -fx-text-fill: #FF4444;" text="❤" />
                <Label fx:id="timerLabel"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #FF4444;"
                       text="20s" />
                <ProgressBar fx:id="timerBar"
                             nodeOrientation="RIGHT_TO_LEFT"
                             prefWidth="80.0" progress="1.0"
                             style="-fx-accent: #FF4444;" />
            </HBox>
        </HBox>

        <!-- Target word card -->
        <StackPane>
            <Rectangle arcHeight="24" arcWidth="24" fill="white" height="110"
                       style="-fx-effect: dropshadow(gaussian, #FF999940, 10, 0, 0, 4);"
                       width="280" />
            <VBox alignment="CENTER" spacing="4">
                <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #66bc5f;"
                       text="PALABRA OBJETIVO" />
                <Label fx:id="targetWord"
                       style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #ff4444;"
                       text="MANZANA" wrapText="true" alignment="CENTER" />
            </VBox>
        </StackPane>

        <!-- Feedback message -->
        <StackPane fx:id="feedbackPane" visible="false">
            <Rectangle fx:id="feedbackBg" arcHeight="20" arcWidth="20"
                       fill="#4CAF50" height="34" opacity="0.85" width="180" />
            <HBox alignment="CENTER" spacing="6">
                <Label fx:id="feedbackLabel"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;"
                       text="¡Correcto!" />
            </HBox>
        </StackPane>

        <!-- Input field -->
        <StackPane>
            <Rectangle arcHeight="14" arcWidth="14" fill="white" height="48"
                       stroke="#FF6B6B" strokeWidth="1.8" width="280" />
            <HBox alignment="CENTER" spacing="8" style="-fx-padding: 0 12 0 12;">
                <TextField fx:id="answerField" alignment="CENTER"
                           promptText="Escribe aquí..."
                           style="-fx-background-color: transparent; -fx-border-color: transparent;
                                  -fx-font-size: 14px; -fx-text-fill: #555555;
                                  -fx-prompt-text-fill: #CCCCCC;"
                           HBox.hgrow="ALWAYS" />
            </HBox>
        </StackPane>

        <!-- Submit button -->
        <StackPane>
            <Rectangle arcHeight="14" arcWidth="14" fill="#EE1111" height="52" width="280" />
            <Button fx:id="submitBtn" onAction="#handleSubmit"
                    style="-fx-background-color: transparent; -fx-font-size: 16px;
                           -fx-font-weight: bold; -fx-text-fill: white; -fx-cursor: hand;"
                    text="¡LISTO!" />
        </StackPane>

        <!-- Score -->
        <HBox alignment="CENTER" spacing="40">
            <VBox alignment="CENTER" spacing="2">
                <Label style="-fx-font-size: 11px; -fx-font-weight: bold;
                              -fx-text-fill: #609da6; -fx-letter-spacing: 1px;"
                       text="PUNTUACIÓN" />
                <Label fx:id="scoreLabel"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #333333;"
                       text="0" />
            </VBox>
        </HBox>

        <!-- Branding -->
        <Label text="🔒 JoType" textFill="#8c0b0b"
               style="-fx-font-size: 11px; -fx-font-style: italic;" />
    </VBox>

    <!-- ═══════════════════════════════════════════
         GAME OVER OVERLAY
         ═══════════════════════════════════════════ -->
    <VBox fx:id="gameOverPane" alignment="CENTER" spacing="20" visible="false"
          style="-fx-background-color: rgba(255,240,240,0.96); -fx-background-radius: 20;">
        <padding>
            <Insets bottom="40" left="30" right="30" top="40" />
        </padding>

        <Label fx:id="gameOverTitle"
               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #EE1111;"
               text="FIN DEL JUEGO" />

        <Label fx:id="gameOverLevels"
               style="-fx-font-size: 16px; -fx-text-fill: #555555;"
               text="Niveles completados: 0" />

        <Label fx:id="gameOverScore"
               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #333333;"
               text="Puntuación final: 0" />

        <!-- Restart button -->
        <StackPane>
            <Rectangle arcHeight="14" arcWidth="14" fill="#EE1111" height="52" width="240" />
            <Button onAction="#handleRestart"
                    style="-fx-background-color: transparent; -fx-font-size: 15px;
                           -fx-font-weight: bold; -fx-text-fill: white; -fx-cursor: hand;"
                    text="🔄 Jugar de nuevo" />
        </StackPane>
    </VBox>

</StackPane>
